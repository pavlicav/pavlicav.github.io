<style>
  :root {
    --ink: #0a0a0a;
    --paper: #f4ede0;
    --paper-warm: #ece2cf;
    --piston-red: #c8102e;
    --piston-blue: #1d428a;
    --magic-blue: #0077c0;
    --magic-black: #000000;
    --highlighter: #fff200;
    --rule: 2px solid var(--ink);
  }

- { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
background: var(–paper);
color: var(–ink);
font-family: ‘Fraunces’, Georgia, serif;
font-optical-sizing: auto;
-webkit-font-smoothing: antialiased;
overflow-x: hidden;
}

/* paper grain texture */
body::before {
content: “”;
position: fixed;
inset: 0;
pointer-events: none;
background-image:
radial-gradient(rgba(0,0,0,0.06) 1px, transparent 1px),
radial-gradient(rgba(0,0,0,0.04) 1px, transparent 1px);
background-size: 3px 3px, 7px 7px;
background-position: 0 0, 1px 2px;
mix-blend-mode: multiply;
z-index: 1;
opacity: 0.5;
}

.wrap {
position: relative;
z-index: 2;
max-width: 1180px;
margin: 0 auto;
padding: 0 24px;
}

/* ============ EMERGENCY BAR ============ */
.emergency {
background: var(–ink);
color: var(–highlighter);
border-bottom: var(–rule);
padding: 8px 0;
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
text-transform: uppercase;
letter-spacing: 0.18em;
overflow: hidden;
white-space: nowrap;
}
.ticker {
display: inline-block;
animation: tick 38s linear infinite;
padding-left: 100%;
}
.ticker span { padding: 0 1.5em; }
.ticker .dot { color: var(–piston-red); }
@keyframes tick {
from { transform: translateX(0); }
to   { transform: translateX(-100%); }
}

/* ============ MASTHEAD ============ */
header.masthead {
border-bottom: var(–rule);
padding: 14px 0 10px;
background: var(–paper);
}
.masthead-row {
display: flex;
justify-content: space-between;
align-items: baseline;
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
text-transform: uppercase;
letter-spacing: 0.2em;
}
.masthead-row .pulse {
display: inline-block;
width: 8px; height: 8px;
background: var(–piston-red);
border-radius: 50%;
margin-right: 8px;
vertical-align: middle;
animation: pulse 1.4s ease-in-out infinite;
}
@keyframes pulse {
0%, 100% { opacity: 1; transform: scale(1); }
50%      { opacity: 0.3; transform: scale(0.7); }
}

/* ============ HERO ============ */
.hero {
padding: 48px 0 24px;
border-bottom: var(–rule);
position: relative;
}

.kicker {
font-family: ‘JetBrains Mono’, monospace;
font-size: 13px;
text-transform: uppercase;
letter-spacing: 0.3em;
color: var(–piston-red);
margin-bottom: 18px;
display: inline-block;
padding: 4px 10px;
background: var(–ink);
color: var(–highlighter);
transform: rotate(-1.5deg);
}

h1.headline {
font-family: ‘Anton’, ‘Bebas Neue’, sans-serif;
font-size: clamp(64px, 13vw, 200px);
line-height: 0.82;
letter-spacing: -0.02em;
text-transform: uppercase;
color: var(–ink);
margin: 8px 0 4px;
}
h1.headline .em {
color: var(–piston-red);
font-style: italic;
}
h1.headline .stroke {
-webkit-text-stroke: 2px var(–ink);
color: transparent;
}

.subhead {
font-family: ‘Fraunces’, serif;
font-style: italic;
font-weight: 400;
font-size: clamp(20px, 2.4vw, 30px);
line-height: 1.25;
max-width: 780px;
margin-top: 24px;
color: #2a2a2a;
}

/* ============ DETAILS STRIP ============ */
.details {
display: grid;
grid-template-columns: repeat(4, 1fr);
border-bottom: var(–rule);
background: var(–paper-warm);
}
.detail {
padding: 22px 20px;
border-right: var(–rule);
}
.detail:last-child { border-right: 0; }
.detail .label {
font-family: ‘JetBrains Mono’, monospace;
font-size: 10px;
letter-spacing: 0.25em;
text-transform: uppercase;
color: #555;
margin-bottom: 8px;
display: block;
}
.detail .value {
font-family: ‘Anton’, sans-serif;
font-size: 28px;
line-height: 1;
text-transform: uppercase;
letter-spacing: 0.01em;
}
.detail .value small {
display: block;
font-family: ‘Fraunces’, serif;
font-style: italic;
font-size: 14px;
font-weight: 400;
text-transform: none;
margin-top: 6px;
color: #555;
letter-spacing: 0;
}

/* ============ MAIN COLUMNS ============ */
.body {
display: grid;
grid-template-columns: 1.4fr 1fr;
gap: 0;
}

.col {
padding: 40px 32px;
}
.col.left {
border-right: var(–rule);
}

h2.section {
font-family: ‘Anton’, sans-serif;
text-transform: uppercase;
font-size: 36px;
letter-spacing: 0.02em;
line-height: 1;
margin-bottom: 6px;
}
.section-rule {
border-bottom: var(–rule);
margin-bottom: 22px;
padding-bottom: 6px;
}
.section-rule .meta {
font-family: ‘JetBrains Mono’, monospace;
font-size: 10px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: #777;
}

.lede {
font-family: ‘Fraunces’, serif;
font-size: 19px;
line-height: 1.55;
margin-bottom: 16px;
}
.lede:first-letter {
font-family: ‘Anton’, sans-serif;
float: left;
font-size: 70px;
line-height: 0.85;
padding: 6px 10px 0 0;
color: var(–piston-red);
}

p.body-copy {
font-family: ‘Fraunces’, serif;
font-size: 17px;
line-height: 1.55;
margin-bottom: 14px;
}
p.body-copy em.hl {
background: var(–highlighter);
font-style: normal;
padding: 0 4px;
}

/* series pill bar */
.series {
display: flex;
gap: 6px;
margin: 18px 0 26px;
align-items: stretch;
}
.game {
flex: 1;
border: var(–rule);
padding: 10px 8px;
text-align: center;
background: var(–paper);
font-family: ‘JetBrains Mono’, monospace;
position: relative;
}
.game .g {
font-size: 9px;
letter-spacing: 0.15em;
text-transform: uppercase;
color: #777;
}
.game .score {
font-family: ‘Anton’, sans-serif;
font-size: 22px;
margin-top: 4px;
letter-spacing: 0.02em;
}
.game.win-det { background: var(–piston-blue); color: #fff; }
.game.win-det .g { color: rgba(255,255,255,0.7); }
.game.win-orl { background: var(–magic-black); color: var(–magic-blue); }
.game.win-orl .g { color: rgba(255,255,255,0.6); }
.game.win-orl .score { color: #fff; }
.game.tomorrow {
background: var(–highlighter);
transform: scale(1.08);
z-index: 3;
box-shadow: 4px 4px 0 var(–ink);
}
.game.tomorrow .g { color: var(–ink); font-weight: 700; }
.game.tomorrow .score { font-size: 16px; line-height: 1.1; padding-top: 2px; }

/* ============ ENTRY INSTRUCTIONS ============ */
.entry {
background: var(–ink);
color: var(–paper);
padding: 32px;
