.stakes h3 {
font-family: ‘Anton’, sans-serif;
text-transform: uppercase;
font-size: 32px;
line-height: 0.95;
margin-top: 4px;
}
.stakes p {
font-family: ‘Fraunces’, serif;
font-style: italic;
margin-top: 8px;
font-size: 16px;
}

/* ============ FOOTER ============ */
footer {
border-top: var(–rule);
padding: 18px 0 24px;
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
text-transform: uppercase;
letter-spacing: 0.2em;
color: #555;
text-align: center;
background: var(–paper-warm);
}
footer .big {
