}
.entry ol li {
counter-increment: step;
padding: 16px 0 16px 56px;
border-bottom: 1px dashed rgba(244,237,224,0.25);
position: relative;
font-family: ‘Fraunces’, serif;
font-size: 17px;
line-height: 1.45;
}
.entry ol li:last-child { border-bottom: 0; }
.entry ol li::before {
content: counter(step);
position: absolute;
left: 0;
top: 14px;
font-family: ‘Anton’, sans-serif;
font-size: 36px;
line-height: 1;
color: var(–piston-red);
}
.entry ol li strong {
font-family: ‘Anton’, sans-serif;
font-weight: 400;
text-transform: uppercase;
letter-spacing: 0.04em;
font-size: 13px;
display: block;
color: var(–highlighter);
margin-bottom: 4px;
}

.address-block {
margin-top: 28px;
padding: 20px;
border: 2px dashed var(–highlighter);
}
.address-block .label {
font-family: ‘JetBrains Mono’, monospace;
font-size: 10px;
letter-spacing: 0.25em;
text-transform: uppercase;
color: var(–highlighter);
}
.address-block .addr {
font-family: ‘Anton’, sans-serif;
font-size: 30px;
line-height: 1.05;
margin-top: 6px;
text-transform: uppercase;
}

/* ============ STAKES BOX ============ */
.stakes {
margin: 20px 0 28px;
padding: 20px;
background: var(–piston-red);
color: #fff;
transform: rotate(-0.6deg);
box-shadow: 6px 6px 0 var(–ink);
